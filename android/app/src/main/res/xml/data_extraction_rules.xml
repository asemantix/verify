<?xml version="1.0" encoding="utf-8"?>
<!-- Opt out of cloud backup and device-to-device transfer entirely:
     the stored seed is device-bound, so copying store.enc to another
     device would be worthless and only creates an attack surface. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
